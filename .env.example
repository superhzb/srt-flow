# Local development defaults.
ENV=dev
AUTH_MODE=dev
DEV_USER_EMAIL=dev@local
DEV_USER_TIER=paid

# Backend job orchestration.
DATABASE_URL=sqlite:///./.data/dev/db.sqlite
WORKERS=mlx=http://localhost:5732,cloud=http://localhost:5733

# Cloud translation worker.
DEEPSEEK_API_KEY=

# Google auth. Required when AUTH_MODE=google.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5730/api/auth/google/callback
JWT_SECRET=
ADMIN_SUBS=
ADMIN_EMAILS=dev@local
ADMIN_SESSION_SECRET=

# Billing. Required only when exercising billing flows.
BILLING_REF_SECRET=
BILLING_PAYMENT_LINK=
FREE_TIER_MONTHLY_LIMIT=10
STRIPE_WEBHOOK_SECRET=
STRIPE_SECRET=
STRIPE_PRICE_ID=
APP_BASE_URL=http://localhost:5730
