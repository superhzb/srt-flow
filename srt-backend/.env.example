# Runtime
ENV=dev                          # dev | staging | prod
LOG_LEVEL=INFO
DATABASE_URL=sqlite:///./.data/dev/db.sqlite
STORAGE_ROOT=./.data/dev/storage
WORKERS=mlx=http://localhost:5732,cloud=http://localhost:5733

# Authentication
AUTH_MODE=dev                    # google | dev (dev requires ENV=dev)
DEV_USER_EMAIL=dev@local
DEV_USER_TIER=paid               # free | paid
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional alternative to GOOGLE_CLIENT_ID/GOOGLE_CLIENT_SECRET:
GOOGLE_CLIENT_JSON=
GOOGLE_REDIRECT_URI=http://localhost:5730/api/auth/google/callback
JWT_SECRET=                      # required when AUTH_MODE=google
JWT_TTL_HOURS=168
APP_REDIRECT_PATH=/
SESSION_COOKIE_NAME=srt_session
CSRF_COOKIE_NAME=srt_oauth_state

# Billing
BILLING_PAYMENT_LINK=https://buy.stripe.com/test_replace_me
BILLING_REF_SECRET=replace-me
STRIPE_WEBHOOK_SECRET=
FREE_TIER_MONTHLY_LIMIT=10
# Configure all three to use Checkout Sessions instead of a Payment Link:
STRIPE_SECRET=
STRIPE_PRICE_ID=
APP_BASE_URL=
