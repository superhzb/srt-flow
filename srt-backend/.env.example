# srt-flow backend env template.
#
# This is the ONE canonical template. Copy to `.env` (dev base). For
# staging/prod, also create `.env.staging` / `.env.prod` carrying only the
# keys that differ from the dev base plus the secrets that env needs.
# Load model: srt-backend/src/srt_backend/app.py loads `.env`, then, when
# ENV != dev, overlays `.env.<ENV>` with override=True.
#
# Only keys that VARY across dev/staging/prod belong here. Keys whose value
# never varies (LOG_LEVEL, JWT_TTL_HOURS, APP_REDIRECT_PATH,
# SESSION_COOKIE_NAME, CSRF_COOKIE_NAME, DEV_USER_EMAIL, DEV_USER_TIER,
# PREPARE_*) are intentionally absent — the in-code default is the source of
# truth. See pkg_auth/config.py, pkg_billing/config.py, pkg_job_orch/config.py.

# --- Runtime ----------------------------------------------------------------
ENV=dev                          # dev | staging | prod
DATABASE_URL=sqlite:///./.data/dev/db.sqlite
STORAGE_ROOT=./.data/dev/storage

# --- Authentication ---------------------------------------------------------
AUTH_MODE=dev                    # google | dev (dev requires ENV=dev)
# Google OAuth. Required when AUTH_MODE=google.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional alternative to GOOGLE_CLIENT_ID/GOOGLE_CLIENT_SECRET:
GOOGLE_CLIENT_JSON=
GOOGLE_REDIRECT_URI=http://localhost:19105/api/auth/google/callback
JWT_SECRET=                      # required when AUTH_MODE=google
# Admin allowlists. In staging/prod set at least one of ADMIN_SUBS (Google
# subject IDs) or ADMIN_EMAILS (Google-verified emails).
ADMIN_SUBS=
ADMIN_EMAILS=dev@local
# Access allowlist. When set (non-empty) in staging/prod, ONLY these Google
# subs/emails may log in — everyone else is bounced at the OAuth callback and
# gets 401 on every route. Leave empty for a public (open) environment such as
# prod. Admins (ADMIN_SUBS/ADMIN_EMAILS) always pass. Staging is locked to a
# single tester via .env.staging (see below).
ALLOWED_SUBS=
ALLOWED_EMAILS=
ADMIN_SESSION_SECRET=            # required outside dev; independent from JWT_SECRET

# --- Billing ----------------------------------------------------------------
BILLING_REF_SECRET=
STRIPE_WEBHOOK_SECRET=
FREE_TIER_MONTHLY_LIMIT=30
# Checkout Sessions is the active path; all four below must be set together
# (or all left unset). Non-prod requires sk_test_; prod requires sk_live_.
STRIPE_SECRET=
STRIPE_SMALL_PRICE_ID=
STRIPE_LARGE_PRICE_ID=
APP_BASE_URL=http://localhost:19105

# --- Translation backends ---------------------------------------------------
# LLM_BACKENDS: comma-separated enabled backend ids (default "mlx,cloud").
# Cloud deploy sets LLM_BACKENDS=cloud only — the mlx row is local dev/test
# only (loopback to the mlx-platform gateway) and never runs in the cloud.
LLM_BACKENDS=cloud
# Required when the "cloud" backend is enabled.
DEEPSEEK_API_KEY=
# Required when the "mlx" backend is enabled (local dev/test only); confirm
# the gateway port with the mlx-platform team before relying on the default.
MLX_PLATFORM_BASE_URL=http://127.0.0.1:5900/v1
