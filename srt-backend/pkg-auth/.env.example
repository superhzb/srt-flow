# pkg-auth config template. Copy to .env and fill secrets. See PLAN.md > Config.
ENV=dev                          # dev | staging | prod
AUTH_MODE=google                 # google | dev  (dev honored only when ENV=dev)
DEV_USER_EMAIL=dev@local         # seeded user for dev mode
DEV_USER_TIER=paid               # test paid features without Stripe

GOOGLE_CLIENT_ID=                # from Google Cloud console OAuth client
GOOGLE_CLIENT_SECRET=            # from Google Cloud console OAuth client
# Optional alternative to GOOGLE_CLIENT_ID/SECRET: paste Google OAuth client JSON.
GOOGLE_CLIENT_JSON=
GOOGLE_REDIRECT_URI=http://localhost:5730/api/auth/google/callback

JWT_SECRET=                      # required when AUTH_MODE=google; gen: python3 -c "import secrets;print(secrets.token_urlsafe(48))"
JWT_TTL_HOURS=168                # 7d session
