# Copy to ~/.config/srt-flow/deploy.env on the deployment Mac and chmod 600 it.
# The deploy script can alternatively read DASHBOARD_DOMAIN and
# DASHBOARD_PASSCODE from ~/Documents/GitHub/brbot-router/.env.

BRBOT_ROUTER_URL=http://127.0.0.1:9000
BRBOT_ROUTER_DASHBOARD_HOST=dashboard.example.com
BRBOT_ROUTER_PASSCODE=replace-me

# Optional path overrides:
# SRT_FLOW_ROOT=/Users/you/Documents/GitHub/srt-flow
# SRT_FLOW_STAGING_CLONE=/path/to/srt-flow-staging/srt-flow
# SRT_FLOW_PRODUCTION_CLONE=/path/to/srt-flow-prod/srt-flow
# SRT_FLOW_DEPLOY_STATE_DIR=/Users/you/Library/Application Support/srt-flow-deploy
